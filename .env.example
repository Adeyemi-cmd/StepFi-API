# ===========================================
# APP CONFIGURATION
# ===========================================
PORT=4000
NODE_ENV=development
API_PREFIX=api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# JWT CONFIGURATION
# ===========================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_min_32_chars_here
# Must differ from JWT_SECRET
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_here

# ===========================================
# STELLAR / SOROBAN CONFIGURATION
# ===========================================
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ===========================================
# CONTRACT ADDRESSES
# ===========================================
# Deploy contracts first — see StepFi-Contracts/scripts/deploy-testnet.sh
REPUTATION_CONTRACT_ID=your_reputation_contract_id
CREDIT_LINE_CONTRACT_ID=your_credit_line_contract_id
MERCHANT_REGISTRY_CONTRACT_ID=your_merchant_registry_contract_id
LIQUIDITY_POOL_CONTRACT_ID=your_liquidity_pool_contract_id

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# CACHE CONFIGURATION
# ===========================================
REPUTATION_CACHE_TTL=300

# ===========================================
# BACKGROUND JOBS
# ===========================================
JOBS_ENABLED=true
INDEXER_INTERVAL=30
TX_STATUS_INTERVAL=15
REMINDER_CRON=0 9 * * *

# ===========================================
# MONITORING
# ===========================================
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=debug
LOG_PRETTY=true
